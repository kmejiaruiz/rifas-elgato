<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Dejar pasar las peticiones a la API directamente
  RewriteCond %{REQUEST_URI} ^/api/ [OR]
  RewriteCond %{REQUEST_URI} ^/api$
  RewriteRule ^ - [L]

  # 2. Redirigir el resto de peticiones al directorio compiled dist/
  RewriteCond %{REQUEST_URI} !^/dist/
  RewriteRule ^(.*)$ dist/$1 [L]
</IfModule>
