<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Si el archivo o directorio existe, servirlo directamente
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  
  # Si la petición empieza con api/, dejar que Apache la procese sin redirección
  RewriteRule ^api/ - [L]

  # Todo lo demás se redirige a index.html para que lo maneje React Router
  RewriteRule ^ index.html [L]
</IfModule>

# ─── CORS headers (siempre, incluso en preflight) ────────────
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Auth-Token, X-CSRF-Token, X-Requested-With, Accept, Origin, Access-Control-Request-Method, Access-Control-Request-Headers"
    Header always set Access-Control-Max-Age "86400"
</IfModule>
