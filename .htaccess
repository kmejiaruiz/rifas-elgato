<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Dejar pasar archivos y directorios reales (assets, imágenes, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 2. Todo lo demás → index.html (React Router se encarga del resto)
  RewriteRule ^ index.html [L]
</IfModule>
